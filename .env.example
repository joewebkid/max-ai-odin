MAX_BOT_TOKEN=your_max_bot_token
DEFAULT_BACKEND=g4f
METRICS_FILE=data/bot-metrics.json
RECENT_REQUESTS_LIMIT=200
TOKEN_CYCLE_DAYS=30
DEFAULT_TARIFF_ID=starter
TARIFFS_JSON=[{"id":"starter","name":"Старт","description":"Для редких обращений и тестов.","priceText":"0 ₽","monthlyTokens":50000,"isPublic":true},{"id":"plus","name":"Плюс","description":"Для ежедневной работы с ботом.","priceText":"990 ₽","monthlyTokens":300000,"isPublic":true},{"id":"pro","name":"Про","description":"Для активного использования и длинных диалогов.","priceText":"3 990 ₽","monthlyTokens":1500000,"isPublic":true}]

# Base URL of your g4f server, without the trailing slash.
# Example:
# G4F_BASE_URL=https://your-g4f-server.example.com
G4F_BASE_URL=

# Supported values:
# - backend-api: POST /backend-api/v2/conversation
# - openai: POST /v1/chat/completions
# - cryptosmi: POST /generate on a custom server
G4F_API_MODE=backend-api

# Optional. Required only if your server expects an API key.
G4F_API_KEY=

# Example values:
# - gpt-4o-mini
# - gpt-4.1-mini
# - deepseek-v3
G4F_MODEL=gpt-4o-mini

# Optional provider name for backend-api mode, for example OpenAI or OpenRouterFree.
G4F_PROVIDER=

# Used only in cryptosmi mode.
G4F_GENERATE_PATH=/generate

# OpenAI-compatible codex-lb endpoint.
# Example:
# CODEX_BASE_URL=https://codex-lb.example.com
CODEX_BASE_URL=
CODEX_API_MODE=openai
CODEX_API_KEY=
CODEX_MODEL=gpt-5.3-codex
CODEX_PROVIDER=
CODEX_GENERATE_PATH=/generate
CODEX_USE_RESPONSES=true
CODEX_SESSION_FILE=data/codex-sessions.json

ADMIN_HOST=127.0.0.1
ADMIN_PORT=3477
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

SYSTEM_PROMPT=Ты полезный русскоязычный ассистент. Отвечай кратко, понятно и по делу.
MAX_HISTORY_MESSAGES=12
REQUEST_TIMEOUT_MS=60000
